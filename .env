LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
OLLAMA_CONTEXT_WINDOW=32768

# vLLM Settings
VLLM_BASE_URL=http://localhost:9090/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_EMBEDDING_MODEL=nomic-embed-text

# Cloud LLM Settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Global Ingestion Settings
EMBEDDING_PROVIDER=ollama
RESOURCE_DIR=RESOURCE
VECTOR_STORE_PROVIDER=chroma
VECTOR_SEARCH_WEIGHT=0.7
VECTOR_DB_PATH=chroma_db_v1
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Reranker & Retrieval Settings
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_THRESHOLD=0.1
LLM_K_FINAL=10
LLM_HISTORY_K=5
LLM_HISTORY_SCORE_THRESHOLD=0.35
CHAT_LLM_NUM_PREDICT=512
DOC_LLM_NUM_CTX=32768

# Website Links (comma-separated defaults)
WEBSITE_LINKS=https://eng.asu.edu.eg

# Database Configuration
DATABASE_URL=mysql+pymysql://octopi_user:root@localhost/octopi_db
INGEST_TABLES=institutes,departments,bylaws,programs,courses

# Auth Settings
ADMIN_USERNAME=ASUAIADMIN
ADMIN_PASSWORD=ASUAIADMIN

# Crawler Settings
DOWNLOAD_FOLDER=offine_downloads
CRAWLER_DB=crawler_data.db
DB_TIMEOUT=300
CRAWL_TIMEOUT=180
CRAWL_RETRIES=3
CRAWL_DELAY=1.0
CRAWL_SKIP_IMAGES=false
# CRAWL_USER_AGENT=   (optional; leave empty for default Chrome-style UA)
ALLOWED_EXTENSIONS=.pdf

# Document Summarization Settings
SUMMARY_CHUNK_SIZE=4000
SUMMARY_CHUNK_OVERLAP=200
SUMMARY_MAX_WORKERS=4
SHOW_SUMMARY_CHUNKS=False
